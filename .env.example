# NIDS Environment Configuration
# Copy this file to .env.local and adjust values

# Node environment
NODE_ENV=development

# JWT Secret - CHANGE THIS IN PRODUCTION
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme-to-a-random-64-char-hex-string

# Server configuration
HOST=0.0.0.0
PORT=3000

# HTTPS configuration (optional)
# Provide paths to TLS certificate and key files
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# CORS origin (Express backend only)
# CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# Database path (SQLite)
DB_PATH=./data/nids.db

# Logging level
LOG_LEVEL=info

# Test credentials (used by test-api.js)
TEST_USER=admin
TEST_PASS=admin123
